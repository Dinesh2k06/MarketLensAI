                "options": { "caseSensitive": true },
                "conditions": [{ "id": "sw_4", "leftValue": "={{ $json.type }}", "rightValue": "refresh", "operator": { "type": "string", "operation": "equals" } }]
              }
            },
            {
              "outputKey": "report",
              "renameOutput": true,
              "conditions": {
                "combinator": "and",
                "options": { "caseSensitive": true },
                "conditions": [{ "id": "sw_5", "leftValue": "={{ $json.type }}", "rightValue": "report", "operator": { "type": "string", "operation": "equals" } }]
              }
            },
            {
              "outputKey": "chat",
              "renameOutput": true,
