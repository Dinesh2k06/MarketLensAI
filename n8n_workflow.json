    {
      "id": "n_code_latest",
      "name": "Format: Latest Analysis",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, -80],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const rows = items.map(i => i.json);\nconst row = rows[0];\nif (!row) return [{ json: { error: 'No analysis found' } }];\nconst analysis = {\n  id: row.id,\n  run_date: row.run_date,\n  status: row.status || 'complete',\n  summary: row.summary || '',\n  comparisons: row.comparisons || [],\n  suggestions: row.suggestions || [],\n  competitors_scouted: row.competitors_scouted || []\n};\nreturn [{ json: analysis }];"
      }
    },

