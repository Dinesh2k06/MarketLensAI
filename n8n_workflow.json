    {
      "id": "n_code_url_extract",
      "name": "Extract Competitor Info from HTML",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 920],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const html = items[0]?.json?.data || items[0]?.json || '';\nconst url = $('Webhook').first().json.url || '';\nconst domain = url.replace(/https?:\\/\\/(www\\.)?/, '').split('/')[0];\nconst name = domain.split('.')[0].replace(/-/g, ' ').replace(/\\b\\w/g, c => c.toUpperCase());\n\n// Extract title from HTML for better name\nlet betterName = name;\nconst titleMatch = String(html).match(/<title[^>]*>([^<]+)<\\/title>/i);\nif (titleMatch) {\n  const rawTitle = titleMatch[1].trim().split(/[|\\-–]/)[0].trim();\n  if (rawTitle.length > 2 && rawTitle.length < 60) {\n    betterName = rawTitle;\n  }\n}\n\nreturn [{ json: { competitor: { name: betterName, website: domain, source: 'url' } } }];"
      }
    },

