    {
      "id": "n_code_daily_prep",
      "name": "Daily: Build AI Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1100, 1200],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const currentUser = $('Loop Over Users').item.json;\nconst products = $('Daily: Get Products').all().map(i => i.json);\nconst competitors = $('Daily: Get Competitors').all().map(i => i.json);\n\nconst today = new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', hour: '2-digit', minute: '2-digit' });\n\nconst productLines = products.map(p => `- ${p.name}: ₹${p.price}, Stock: ${p.stock || 0}`).join('\\n') || '- No products';\nconst competitorLines = competitors.map(c => `- ${c.name}`).join('\\n') || '- No competitors';\n\nconst prompt = `Competitive pricing analysis for ${currentUser.company_name || 'a retail business'}.\n\nMY PRODUCTS:\\n${productLines}\\n\\nCOMPETITORS:\\n${competitorLines}\\n\\nGenerate realistic market analysis. Return ONLY valid JSON:\\n{\"summary\":\"...\",\"comparisons\":[{\"id\":1,\"my_product\":\"...\",\"my_price\":0,\"my_stock\":0,\"competitor\":\"...\",\"competitor_price\":0,\"diff\":0,\"status\":\"optimal\",\"trend\":\"flat\"}],\"suggestions\":[{\"id\":1,\"priority\":\"medium\",\"icon\":\"trending-up\",\"title\":\"...\",\"body\":\"...\",\"impact\":\"...\"}],\"competitors_scouted\":[{\"name\":\"...\",\"website\":\"\",\"products_tracked\":3,\"last_scraped\":\"Today ${today}\"}]}`;\n\nreturn [{ json: { prompt, userId: currentUser.id, userEmail: currentUser.gmail, company: currentUser.company_name } }];"
      }
    },

    {
      "id": "n_http_daily_gemini",
      "name": "Daily: Gemini Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1320, 1200],
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={{ $env.GEMINI_API_KEY }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ contents: [{ role: 'user', parts: [{ text: $json.prompt }] }], generationConfig: { temperature: 0.3, maxOutputTokens: 2048 } }) }}",
        "options": {}
      }
    },

    {
      "id": "n_code_daily_parse",
      "name": "Daily: Parse & Save Analysis",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1540, 1200],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const geminiOut = $('Daily: Gemini Analysis').first().json;\nconst prep = $('Daily: Build AI Prompt').first().json;\n\nlet rawText = '';\ntry { rawText = geminiOut.candidates[0].content.parts[0].text || ''; } catch(e) {}\n\nlet analysis = {};\ntry {\n  const jsonStr = rawText.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n  analysis = JSON.parse(jsonStr);\n} catch(e) {\n  analysis = { summary: 'Daily analysis complete. Review your pricing.', comparisons: [], suggestions: [], competitors_scouted: [] };\n}\n\nconst payload = {\n  user_id: prep.userId,\n  run_date: new Date().toISOString(),\n  status: 'complete',\n  summary: analysis.summary || '',\n  comparisons: analysis.comparisons || [],\n  suggestions: analysis.suggestions || [],\n  competitors_scouted: analysis.competitors_scouted || []\n};\n\nreturn [{ json: { analysis: payload, userEmail: prep.userEmail, company: prep.company, userId: prep.userId } }];"
      }
    },

