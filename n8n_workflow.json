    {
      "id": "code-dly-prompt",
      "name": "Daily: Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1440, 1820],
      "parameters": {
        "jsCode": "const user = $('Loop Each User').item.json;\nconst products = $('Daily: Get Products').all().map(i => i.json);\nconst competitors = $('Daily: Get Competitors').all().map(i => i.json);\nconst pList = products.length ? products.map(p => `- ${p.name}: ₹${p.price}, Stock: ${p.stock||'N/A'}`).join('\\n') : 'No products yet';\nconst cList = competitors.length ? competitors.map(c => `- ${c.name} (${c.website||'no website'})`).join('\\n') : 'No competitors yet';\nconst prompt = `Analyze the business data for ${user.company_name}. Return ONLY raw JSON (no markdown):\\n{\"summary\":\"...\",\"comparisons\":[{\"my_product\":\"...\",\"my_price\":0,\"competitor\":\"...\",\"competitor_price\":0,\"status\":\"undercut|optimal|no_data\"}],\"suggestions\":[{\"priority\":\"high|medium|low\",\"title\":\"...\",\"body\":\"...\",\"impact\":\"...\"}],\"competitors_scouted\":[]}\\n\\nMY PRODUCTS:\\n${pList}\\n\\nMY COMPETITORS:\\n${cList}`;\nreturn [{ json: { prompt, user } }];"
      }
    },

