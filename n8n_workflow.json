            },
            {
              "outputKey": "analysis_latest",
              "renameOutput": true,
              "conditions": {
                "combinator": "and",
                "options": { "caseSensitive": true },
                "conditions": [
                  { "id": "sw_2a", "leftValue": "={{ $json.type }}", "rightValue": "analysis", "operator": { "type": "string", "operation": "equals" } },
                  { "id": "sw_2b", "leftValue": "={{ $json.action }}", "rightValue": "latest", "operator": { "type": "string", "operation": "equals" } }
                ]
              }
            },
            {
              "outputKey": "analysis_history",
              "renameOutput": true,
              "conditions": {
                "combinator": "and",
                "options": { "caseSensitive": true },
                "conditions": [
                  { "id": "sw_3a", "leftValue": "={{ $json.type }}", "rightValue": "analysis", "operator": { "type": "string", "operation": "equals" } },
                  { "id": "sw_3b", "leftValue": "={{ $json.action }}", "rightValue": "history", "operator": { "type": "string", "operation": "equals" } }
                ]
              }
            },
            {
              "outputKey": "refresh",
              "renameOutput": true,
