    {
      "id": "code-dly-parse",
      "name": "Daily: Parse Analysis",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1920, 1820],
      "parameters": {
        "jsCode": "const user = $('Daily: Build Prompt').first().json.user;\nconst raw = $json.output || '{}';\nlet analysis;\ntry {\n  const cleaned = raw.replace(/```json\\s*/gi, '').replace(/```\\s*/g, '').trim();\n  analysis = JSON.parse(cleaned);\n} catch (e) {\n  analysis = { summary: raw.substring(0, 300), comparisons: [], suggestions: [], competitors_scouted: [] };\n}\nreturn [{ json: { user, analysis } }];"
      }
    },

    {
      "id": "http-dly-save",
      "name": "Daily: Save Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2160, 1820],
      "parameters": {
        "method": "POST",
        "url": "=https://YOUR_PROJECT_ID.supabase.co/rest/v1/analyses",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "apikey", "value": "=YOUR_ANON_KEY" }, { "name": "Authorization", "value": "=Bearer YOUR_ANON_KEY" }, { "name": "Content-Type", "value": "application/json" }, { "name": "Prefer", "value": "return=representation" }] },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ user_id: $json.user.id, run_date: new Date().toISOString(), status: 'complete', summary: $json.analysis.summary, comparisons: $json.analysis.comparisons, suggestions: $json.analysis.suggestions, competitors_scouted: $json.analysis.competitors_scouted }) }}",
        "options": {}
      }
    },

    {
      "id": "code-dly-email",
      "name": "Daily: Build Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2400, 1820],
      "parameters": {
        "jsCode": "const { user, analysis } = $('Daily: Parse Analysis').first().json;\nconst sc = s => s === 'undercut' ? '#e53e3e' : s === 'optimal' ? '#38a169' : '#94a3b8';\nconst rows = (analysis.comparisons||[]).map(c => `<tr><td style='padding:8px;border:1px solid #e2e8f0'>${c.my_product}</td><td style='padding:8px;border:1px solid #e2e8f0'>&#8377;${c.my_price}</td><td style='padding:8px;border:1px solid #e2e8f0'>${c.competitor}</td><td style='padding:8px;border:1px solid #e2e8f0'>&#8377;${c.competitor_price}</td><td style='padding:8px;border:1px solid #e2e8f0;color:${sc(c.status)}'>${c.status}</td></tr>`).join('');\nconst suggs = (analysis.suggestions||[]).map(s => `<li style='margin-bottom:8px'><strong>[${(s.priority||'').toUpperCase()}]</strong> ${s.title}: ${s.body}</li>`).join('');\nconst html = `<html><body style='font-family:sans-serif;max-width:600px;margin:0 auto;padding:24px'><h2 style='color:#4f46e5'>&#128202; Daily Market Intelligence &#8212; ${user.company_name}</h2><p style='color:#64748b'>${new Date().toLocaleDateString('en-IN',{weekday:'long',year:'numeric',month:'long',day:'numeric'})}</p><hr style='border:none;border-top:1px solid #e2e8f0;margin:16px 0'><h3>Summary</h3><p>${analysis.summary}</p><h3>Product Comparison</h3><table style='width:100%;border-collapse:collapse;font-size:14px'><tr style='background:#f8fafc;font-weight:600'><th style='padding:8px;border:1px solid #e2e8f0;text-align:left'>Product</th><th style='padding:8px;border:1px solid #e2e8f0;text-align:left'>Your Price</th><th style='padding:8px;border:1px solid #e2e8f0;text-align:left'>Competitor</th><th style='padding:8px;border:1px solid #e2e8f0;text-align:left'>Their Price</th><th style='padding:8px;border:1px solid #e2e8f0;text-align:left'>Status</th></tr>${rows}</table><h3>Recommendations</h3><ul style='padding-left:20px'>${suggs}</ul><p style='color:#94a3b8;font-size:12px;margin-top:24px'>Powered by MarketLensAI</p></body></html>`;\nconst subject = `&#128202; Daily Market Intelligence &#8212; ${user.company_name} &#8212; ${new Date().toLocaleDateString('en-IN')}`;\nreturn [{ json: { html, recipient: user.gmail, user, subject } }];"
      }
    },

