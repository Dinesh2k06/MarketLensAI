      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const data = $('Webhook').first().json;\nconst location = data.location || 'India';\nconst businessType = data.business_type || 'retail';\n\n// This branch requires a SerpAPI or Google Places key.\n// Set SERP_API_KEY in n8n environment variables to enable real search.\n// Without it, we return region-specific mock competitors.\n\nconst mockCompetitors = [\n  { name: 'Local Textile Hub', website: 'localtextilehub.in', location, distance: '0.8 km' },\n  { name: 'City Fashion House', website: 'cityfashionhouse.com', location, distance: '1.2 km' },\n  { name: 'National Handlooms', website: 'nationalhandlooms.com', location, distance: '1.5 km' },\n  { name: 'Ethnic Weaves', website: 'ethnicweaves.in', location, distance: '2.1 km' },\n  { name: 'Style Palace', website: 'stylepalace.in', location, distance: '2.4 km' },\n  { name: `${businessType.charAt(0).toUpperCase()+businessType.slice(1)} Mart`, website: 'retailmart.in', location, distance: '3.0 km' },\n];\n\nreturn [{ json: { competitors: mockCompetitors } }];"
      }
    },

