      "parameters": {
        "jsCode": "// Returns mock results. To enable real search: add SerpAPI HTTP node before this.\n// SerpAPI: GET https://serpapi.com/search.json?q=BUSINESS_TYPE+near+LOCATION&api_key=KEY\nconst loc = $json.location || 'your area';\nconst bt  = $json.business_type || 'business';\nreturn [{ json: { competitors: [\n  { name: `${bt} Mart — ${loc}`,   website: '', location: loc, distance: '0.5 km' },\n  { name: `${loc} ${bt} Store`,     website: '', location: loc, distance: '1.1 km' },\n  { name: `New ${bt} Hub`,          website: '', location: loc, distance: '2.3 km' }\n] } }];"
      }
    },

