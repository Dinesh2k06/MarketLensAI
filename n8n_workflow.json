    {
      "id": "n_code_chat_prep",
      "name": "Build Chat Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 600],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const data = $('Webhook').first().json;\nconst message = data.message || '';\nconst history = data.history || [];\n\nconst contents = history.map(m => ({\n  role: m.role === 'user' ? 'user' : 'model',\n  parts: [{ text: m.text }]\n}));\n\ncontents.push({ role: 'user', parts: [{ text: message }] });\n\nreturn [{ json: { contents, message } }];"
      }
    },

