    {
      "id": "n_code_refresh_prep",
      "name": "Build AI Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 200],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const products = $('Supabase: Get Products').all().map(i => i.json);\nconst competitors = $('Supabase: Get Competitors').all().map(i => i.json);\nconst userRow = $('Supabase: Get User').first().json;\n\nconst user = {\n  company: userRow.company_name || 'My Business',\n  type: userRow.business_type || 'Retail',\n  location: userRow.location || 'India'\n};\n\nconst productLines = products.map(p =>\n  `- ${p.name}: ₹${p.price}, Stock: ${p.stock || 0}, Type: ${p.type || 'General'}`\n).join('\\n') || '- No products found';\n\nconst competitorLines = competitors.map(c =>\n  `- ${c.name} (${c.website || 'no website'})`\n).join('\\n') || '- No competitors tracked';\n\nconst today = new Date().toLocaleString('en-IN', { timeZone: 'Asia/Kolkata', hour: '2-digit', minute: '2-digit' });\n\nconst prompt = `You are a market intelligence analyst for an Indian retail business.\n\nBUSINESS: ${user.company} | Type: ${user.type} | Location: ${user.location}\n\nMY PRODUCTS:\n${productLines}\n\nTRACKED COMPETITORS:\n${competitorLines}\n\nTask: Generate a realistic competitive pricing analysis. For each product, simulate a plausible competitor price based on typical market rates for ${user.type} businesses in India. Consider that competition is usually within ±25% of listed price.\n\nReturn ONLY valid JSON (no markdown, no explanation) in exactly this structure:\n{\n  \"summary\": \"2-3 sentence overview of market conditions and key threats/opportunities\",\n  \"comparisons\": [\n    {\n      \"id\": 1,\n      \"my_product\": \"Product Name\",\n      \"my_price\": 1234,\n      \"my_stock\": 45,\n      \"competitor\": \"Competitor Name\",\n      \"competitor_price\": 1150,\n      \"diff\": 84,\n      \"status\": \"undercut\",\n      \"trend\": \"down\"\n    }\n  ],\n  \"suggestions\": [\n    {\n      \"id\": 1,\n      \"priority\": \"high\",\n      \"icon\": \"trending-down\",\n      \"title\": \"Short action title\",\n      \"body\": \"Specific actionable advice for this business\",\n      \"impact\": \"Expected revenue or strategic impact\"\n    }\n  ],\n  \"competitors_scouted\": [\n    {\n      \"name\": \"Competitor Name\",\n      \"website\": \"website.com\",\n      \"products_tracked\": 5,\n      \"last_scraped\": \"Today ${today}\"\n    }\n  ]\n}\n\nRules:\n- status must be exactly one of: undercut (competitor cheaper), optimal (I am cheaper), tied (same price ±2%)\n- trend must be one of: up, down, flat\n- diff = my_price - competitor_price (positive means I am more expensive)\n- Generate 2-4 high-value suggestions specific to this business\n- Match each product to the most relevant competitor from the list\n- Return valid JSON only, no extra text`;\n\nreturn [{ json: { prompt, products, competitors, user, userId: $('Webhook').first().json.user_id } }];"
      }
    },

    {
      "id": "n_http_gemini_refresh",
      "name": "Gemini: Generate Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1340, 200],
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={{ $env.GEMINI_API_KEY }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ contents: [{ role: 'user', parts: [{ text: $json.prompt }] }], generationConfig: { temperature: 0.3, maxOutputTokens: 3000 } }) }}",
        "options": {}
      }
    },

    {
      "id": "n_code_refresh_parse",
      "name": "Parse AI Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 200],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const geminiOutput = $('Gemini: Generate Analysis').first().json;\nconst prepData = $('Build AI Prompt').first().json;\n\nlet rawText = '';\ntry {\n  rawText = geminiOutput.candidates[0].content.parts[0].text || '';\n} catch(e) {\n  console.log('Gemini parse error:', e.message);\n}\n\n// Strip markdown code blocks if present\nlet jsonStr = rawText.replace(/```json\\n?/g, '').replace(/```\\n?/g, '').trim();\n\nlet analysis;\ntry {\n  analysis = JSON.parse(jsonStr);\n} catch(e) {\n  // Fallback: build basic analysis from raw product data\n  const products = prepData.products || [];\n  const competitors = prepData.competitors || [];\n  analysis = {\n    summary: 'Analysis generated. Review your product pricing against local competitors.',\n    comparisons: products.slice(0, 5).map((p, i) => ({\n      id: i + 1,\n      my_product: p.name,\n      my_price: p.price || 0,\n      my_stock: p.stock || 0,\n      competitor: competitors[i % competitors.length]?.name || 'Competitor',\n      competitor_price: Math.round((p.price || 0) * (0.9 + Math.random() * 0.2)),\n      diff: 0,\n      status: 'optimal',\n      trend: 'flat'\n    })),\n    suggestions: [{\n      id: 1,\n      priority: 'medium',\n      icon: 'trending-up',\n      title: 'Review your pricing strategy',\n      body: 'Connect more competitors and run a fresh analysis for accurate insights.',\n      impact: 'Better market positioning'\n    }],\n    competitors_scouted: competitors.map(c => ({ name: c.name, website: c.website || '', products_tracked: 3, last_scraped: 'Today' }))\n  };\n}\n\n// Recalculate diff for all comparisons\nif (analysis.comparisons) {\n  analysis.comparisons = analysis.comparisons.map((c, i) => ({\n    ...c,\n    id: i + 1,\n    diff: (c.my_price || 0) - (c.competitor_price || 0)\n  }));\n}\n\nconst payload = {\n  user_id: prepData.userId,\n  run_date: new Date().toISOString(),\n  status: 'complete',\n  summary: analysis.summary || '',\n  comparisons: analysis.comparisons || [],\n  suggestions: analysis.suggestions || [],\n  competitors_scouted: analysis.competitors_scouted || []\n};\n\nreturn [{ json: payload }];"
      }
    },

