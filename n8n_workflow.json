    {
      "id": "code-cu",
      "name": "Format Competitor URL Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1440, 1120],
      "parameters": {
        "jsCode": "const rawUrl = $('Route by Type').first().json.url;\nconst raw = $json.output || '';\nlet name = 'Unknown Business';\ntry {\n  const cleaned = raw.replace(/```json\\s*/gi, '').replace(/```\\s*/g, '').trim();\n  name = JSON.parse(cleaned).name || 'Unknown Business';\n} catch (e) {\n  try { name = new URL(rawUrl).hostname.replace('www.', ''); } catch (e2) { name = rawUrl; }\n}\nlet website = rawUrl;\ntry { website = new URL(rawUrl).hostname.replace('www.', ''); } catch (e) {}\nreturn [{ json: { competitor: { name, website, source: 'url' } } }];"
      }
    },

