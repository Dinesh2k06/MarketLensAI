# Copy this file to .env and fill in your values
# Never commit your real .env file to git

# Supabase — get from https://supabase.com → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key-here

# Google Gemini AI — free key at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your-gemini-key-here

# n8n Cloud Webhook — single URL handles all operations via the "type" field
VITE_N8N_WEBHOOK=https://your.n8n.cloud/webhook/business-strategy
